# =============================================================================
# Agentic Marketing Platform — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_ENV=development                    # development | production
LOG_LEVEL=INFO                        # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=json                       # json | text

# Secret key for session/token signing (generate with: openssl rand -hex 32)
SECRET_KEY=change-me-in-production

# ------------------------------------------------------------------blog---------
# Database
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/agentic_marketing
DATABASE_URL_SYNC=postgresql://user:password@localhost:5432/agentic_marketing

# Redis (for job queues / caching)
REDIS_URL=redis://localhost:6379/0

# Qdrant (vector store)
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=agentic_marketing
QDRANT_API_KEY=                        # optional

# -----------------------------------------------------------------------------
# LLM Providers (for CHAI review, copy generation)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=                       # sk-... (for review_chain, copy_chain)
OPENAI_MODEL=gpt-4o-mini               # gpt-4o-mini | gpt-4o

ANTHROPIC_API_KEY=                    # sk-ant-... (alternative LLM)

# -----------------------------------------------------------------------------
# Social Media APIs
# -----------------------------------------------------------------------------

# Twitter / X
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=
TWITTER_BEARER_TOKEN=

# LinkedIn
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_ORG_ID=                       # Your LinkedIn Company Page URN

# Meta / Facebook
META_ACCESS_TOKEN=
META_PAGE_ID=

# Buffer
BUFFER_ACCESS_TOKEN=
BUFFER_API_KEY=

# -----------------------------------------------------------------------------
# Image Generation (FLUX via Modal)
# -----------------------------------------------------------------------------
MODAL_TOKEN_ID=                        # from modal.com/settings
MODAL_TOKEN_SECRET=                   # from modal.com/settings
FLUX_MODEL=flux-schnell                # flux-schnell | flux-dev

# HuggingFace (for gated models)
HF_TOKEN=                              # needed for FLUX

# -----------------------------------------------------------------------------
# Search & Research
# -----------------------------------------------------------------------------
SERPER_API_KEY=                        # SerpAPI key for Google search
TAVILY_API_KEY=                        # Tavily AI search

# -----------------------------------------------------------------------------
# Email (for notifications)
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=notifications@example.com

# -----------------------------------------------------------------------------
# Analytics & Monitoring
# -----------------------------------------------------------------------------
POSTHOG_API_KEY=                       # posthog.com
SENTRY_DSN=                             # sentry.io

# -----------------------------------------------------------------------------
# File Storage
# -----------------------------------------------------------------------------
S3_BUCKET=agentic-marketing-assets
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60